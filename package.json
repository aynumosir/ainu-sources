{
	"name": "ainu-sources",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"build": "wrangler types && vite build",
		"deploy": "npm run build && wrangler deploy",
		"seed": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import-all.ts",
		"seed:plan": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import-all.ts --dry-run",
		"seed:legacy-wipe": "bun scripts/seed-legacy-wipe.ts",
		"backup": "bun scripts/backup-db.ts",
		"backup:libsql": "bun scripts/backup-libsql.ts",
		"restore:libsql": "bun scripts/restore-libsql.ts",
		"golden:dump": "bun scripts/golden-dump.ts",
		"bootstrap": "bun scripts/bootstrap-ledger.ts",
		"import:dictionaries": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/dictionaries.ts",
		"import:manual": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/manual.ts",
		"import:grammar": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/grammar.ts",
		"import:corpus": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/corpus.ts",
		"import:curated-biblio": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/curated-biblio.ts",
		"import:academic": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/academic.ts",
		"import:relations": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/relations.ts",
		"import:extracted-cites": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/extracted-cites.ts",
		"sweep:references": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/sweep-references.ts",
		"import:person-enrichment": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import/person-enrichment.ts",
		"import:all": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/import-all.ts",
		"archive:ingest-ocr": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/ingest-ocr.ts",
		"archive:export-approved": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/export-approved.ts",
		"archive:verify-approved": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/verify-approved.ts",
		"archive:search-eval": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/search-eval.ts",
		"audit": "bun scripts/audit.ts",
		"reslug": "bun scripts/apply-reslug.ts",
		"review:proposals": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/review-proposals.ts",
		"apply:approved": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/apply-approved.ts",
		"check:fk": "bun scripts/check-fk-enforcement.ts",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen": "wrangler types",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"archive:realign-pdf-text": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/realign-pdf-text.ts",
		"archive:survey-text-layers": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/survey-text-layers.ts",
		"archive:recognize-pages": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/recognize-pages.ts",
		"archive:detect-folios": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/detect-folios.ts",
		"archive:assess-text-quality": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/assess-text-quality.ts",
		"archive:refresh-significance": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/refresh-significance.ts",
		"archive:gen-derivatives": "bun --preload ./scripts/sveltekit-env-shim.ts scripts/archive/gen-derivatives.ts"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@inlang/paraglide-js": "^2.15.2",
		"@libsql/client": "^0.17.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"mdsvex": "^0.12.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.9",
		"wrangler": "^4.86.0"
	},
	"dependencies": {
		"3d-force-graph": "^1.80.0",
		"ainconv": "0.6.0",
		"jose": "^6.2.3",
		"maplibre-gl": "^5.24.0"
	}
}
