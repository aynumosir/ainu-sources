# --- Database (Drizzle + libSQL/Turso) ---
# Local development: a file-backed SQLite DB is easiest.
DATABASE_URL="file:local.db"
DATABASE_AUTH_TOKEN="dev"
# Production (Turso): a hosted libSQL URL + token, e.g.
# DATABASE_URL="libsql://ainu-sources-<org>.turso.io"
# DATABASE_AUTH_TOKEN="<turso auth token>"

# Public origin (used by better-auth as baseURL)
ORIGIN="http://localhost:5173"
# Production: ORIGIN="https://db.aynu.org"

# --- Better Auth ---
# Generate a high-entropy 32+ char secret for production.
BETTER_AUTH_SECRET="dev-secret-change-me"
# GitHub OAuth (optional — email/password works without it)
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Seed ---
# Root that contains the sibling data repos (ainu-dictionaries, ainu-grammar,
# ainu-corpora). Defaults to two levels up from scripts/. Override if needed:
# AINU_ROOT="/home/you/projects/Ainu"
